{
  "_comment": "포렌식 수집 도구 설정 파일 예시. config.json으로 복사 후 사용하세요.",
  "_security_warning": "API 키는 환경변수(COLLECTOR_API_KEY)로 설정하세요. 이 파일에 직접 입력하지 마세요!",
  "server": {
    "url": "https://your-server.example.com",
    "_api_key_note": "환경변수 COLLECTOR_API_KEY 사용 권장. 이 파일에 API 키를 저장하지 마세요!",
    "verify_ssl": true,
    "timeout_seconds": 300
  },
  "collection": {
    "output_directory": "./collected_artifacts",
    "include_deleted_files": true,
    "calculate_hashes": true,
    "hash_algorithms": [
      "md5",
      "sha256"
    ],
    "max_file_size_mb": 1024,
    "temp_directory": "./temp"
  },
  "upload": {
    "enabled": false,
    "encrypt_before_upload": true,
    "auto_verify": true,
    "retry_attempts": 3,
    "chunk_size_mb": 10
  },
  "logging": {
    "level": "INFO",
    "file": "./logs/collector.log",
    "max_size_mb": 50,
    "backup_count": 5
  },
  "security": {
    "encryption_algorithm": "AES-256-GCM",
    "key_derivation": "HKDF-SHA256",
    "min_tls_version": "TLSv1.2",
    "certificate_pinning": false
  },
  "advanced": {
    "parallel_collection": false,
    "max_threads": 4,
    "memory_limit_mb": 512,
    "debug_mode": false
  }
}