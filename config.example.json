{
  "_comment": "포렌식 수집 도구 설정 파일 예시. config.json으로 복사 후 사용하세요.",

  "server": {
    "url": "https://your-server.example.com",
    "api_key": "YOUR_API_KEY_HERE",
    "verify_ssl": true,
    "timeout_seconds": 300
  },

  "collection": {
    "output_directory": "./collected_artifacts",
    "include_deleted_files": true,
    "calculate_hashes": true,
    "hash_algorithms": ["md5", "sha256"],
    "max_file_size_mb": 1024,
    "temp_directory": "./temp"
  },

  "upload": {
    "enabled": false,
    "encrypt_before_upload": true,
    "auto_verify": true,
    "retry_attempts": 3,
    "chunk_size_mb": 10
  },

  "logging": {
    "level": "INFO",
    "file": "./logs/collector.log",
    "max_size_mb": 50,
    "backup_count": 5
  },

  "artifacts": {
    "windows": {
      "enabled": true,
      "types": ["prefetch", "eventlog", "registry", "browser", "usb"]
    },
    "linux": {
      "enabled": true,
      "types": ["syslog", "auth_log", "bash_history", "ssh"]
    },
    "macos": {
      "enabled": true,
      "types": ["unified_log", "safari", "launch_agents", "knowledgec"]
    },
    "android": {
      "enabled": true,
      "require_root": false,
      "types": ["sms", "contacts", "call_logs", "media", "logcat"]
    },
    "ios": {
      "enabled": true,
      "backup_path": null,
      "types": ["sms", "contacts", "safari", "app_data"]
    }
  },

  "security": {
    "encryption_algorithm": "AES-256-GCM",
    "key_derivation": "HKDF-SHA256",
    "min_tls_version": "TLSv1.2",
    "certificate_pinning": false
  },

  "advanced": {
    "parallel_collection": false,
    "max_threads": 4,
    "memory_limit_mb": 512,
    "debug_mode": false
  }
}
