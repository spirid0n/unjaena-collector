# Collector Environment Variables
# Copy this file to .env and update values as needed

# Server URL (use HTTPS in production!)
COLLECTOR_SERVER_URL=https://your-server.com
FORENSIC_SERVER_URL=https://your-server.com

# For local development only (never use HTTP in production)
# COLLECTOR_SERVER_URL=http://127.0.0.1:8000
# FORENSIC_SERVER_URL=http://127.0.0.1:8000
